{
  "awsAuthRefresh": "aws sso login --profile local-bedrock",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "WebFetch",
      "WebSearch",
      "Search",
      "Bash(* --help)",
      "Bash(* --version)",
      "Bash(rg *)",
      "Bash(less *)",
      "Bash(more *)",
      "Bash(type *)",
      "Bash(jq *)",
      "Bash(env)",
      "Bash(printenv*)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(mktemp*)",
      "Bash(git *)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(gh release view*)",
      "Bash(gh release list*)",
      "Bash(gh api *)",
      "Bash(kube * get *)",
      "Bash(kube * describe *)",
      "Bash(kube * logs *)",
      "Bash(kube * top *)",
      "Bash(kube * explain *)",
      "Bash(kube * version *)",
      "Bash(kube * api-resources *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl top *)",
      "Bash(kubectl explain *)",
      "Bash(kubectl version*)",
      "Bash(kubectl api-resources*)",
      "Bash(curl *)",
      "Bash(brew list*)",
      "Bash(brew info *)",
      "Bash(brew search *)",
      "Bash(ps *)",
      "Bash(pgrep *)",
      "Bash(lsof *)",
      "Bash(aws * get-*)",
      "Bash(aws * list-*)",
      "Bash(aws * describe-*)",
      "Bash(aws cloudtrail lookup-events *)",
      "Bash(aws logs filter-log-events *)",
      "mcp__datadog-mcp__analyze_datadog_logs",
      "mcp__datadog-mcp__get_datadog_incident",
      "mcp__datadog-mcp__get_datadog_metric",
      "mcp__datadog-mcp__get_datadog_metric_context",
      "mcp__datadog-mcp__get_datadog_notebook",
      "mcp__datadog-mcp__get_datadog_trace",
      "mcp__datadog-mcp__search_datadog_dashboards",
      "mcp__datadog-mcp__search_datadog_events",
      "mcp__datadog-mcp__search_datadog_hosts",
      "mcp__datadog-mcp__search_datadog_incidents",
      "mcp__datadog-mcp__search_datadog_logs",
      "mcp__datadog-mcp__search_datadog_metrics",
      "mcp__datadog-mcp__search_datadog_monitors",
      "mcp__datadog-mcp__search_datadog_notebooks",
      "mcp__datadog-mcp__search_datadog_rum_events",
      "mcp__datadog-mcp__search_datadog_service_dependencies",
      "mcp__datadog-mcp__search_datadog_services",
      "mcp__datadog-mcp__search_datadog_spans"
    ],
    "ask": [
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr close *)",
      "Bash(gh issue create *)",
      "Bash(gh issue close *)",
      "Bash(gh repo delete *)",
      "Bash(kube * exec *)",
      "Bash(kube * port-forward *)",
      "Bash(kubectl exec *)",
      "Bash(kubectl port-forward *)",
      "Bash(curl -X POST *)",
      "Bash(curl * -X POST *)",
      "Bash(curl -X PUT *)",
      "Bash(curl * -X PUT *)",
      "Bash(curl -X PATCH *)",
      "Bash(curl * -X PATCH *)",
      "Bash(rm *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(brew install *)",
      "Bash(brew uninstall *)",
      "Bash(npm install *)",
      "Bash(yarn add *)",
      "Bash(bun add *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f*)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Bash(git push --mirror*)",
      "Bash(git push * --mirror*)",
      "Bash(git push * +*)",
      "Bash(git commit --amend*)",
      "Bash(git commit * --amend*)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit * --no-verify*)",
      "Bash(git rebase -i*)",
      "Bash(git rebase --interactive*)",
      "Bash(git reset --hard*)",
      "Bash(git reset * --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean * -f*)",
      "Bash(git branch -D*)",
      "Bash(git branch --delete --force*)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(kube * apply *)",
      "Bash(kube * delete *)",
      "Bash(kube * patch *)",
      "Bash(kube * edit *)",
      "Bash(kube * rollout restart *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl delete *)",
      "Bash(kubectl patch *)",
      "Bash(kubectl edit *)",
      "Bash(kubectl rollout restart *)",
      "Bash(curl -X DELETE *)",
      "Bash(curl * -X DELETE *)",
      "Bash(curl * --data-raw * -X POST *)",
      "Bash(curl * -X POST * --data-raw *)",
      "Bash(aws ssm * --with-decryption*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.envrc)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.config/gh/hosts.yml)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-branch-base.sh",
            "statusMessage": "ブランチのベースを確認中..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "devin-mcp@wantedly-cc-plugins": true,
    "marp-wantedly@wantedly-cc-plugins": true,
    "ruby-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "infra-squad@wantedly-cc-plugins": true
  },
  "extraKnownMarketplaces": {
    "wantedly-cc-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/wantedly/claude-code-plugins.git"
      },
      "autoUpdate": true
    }
  },
  "language": "Japanese",
  "effortLevel": "high",
  "promptSuggestionEnabled": false
}
